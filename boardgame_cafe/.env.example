# Board Game Café - Environment Configuration

# Database
DATABASE_URL=sqlite:///./boardgame_cafe.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (SMTP)
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Application
DEBUG=True
APP_NAME=Board Game Café

VIPPS_API_BASE=https://api.vipps.no
# Leave these unset to trigger simulation mode:
# VIPPS_SUBSCRIPTION_KEY=
# VIPPS_CLIENT_ID=
# VIPPS_CLIENT_SECRET=
VIPPS_MERCHANT_SERIAL_NUMBER=fake-msn
VIPPS_CALLBACK_PREFIX=http://localhost:5000

# Celery + Redis Pub/Sub
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/2
REALTIME_EVENTS_CHANNEL=boardgame_cafe.events