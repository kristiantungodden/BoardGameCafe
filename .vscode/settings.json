{
    "dotnet.defaultSolution": "BordgameCafe.slnx",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.useEnvFile": true,
    "python.envFile": "${workspaceFolder}/boardgame_cafe/.env",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestPath": "${workspaceFolder}/.venv/Scripts/pytest.exe",
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.cwd": "${workspaceFolder}/boardgame_cafe",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/boardgame_cafe/src"
    ]
}